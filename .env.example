# Copy this file to .env and fill in your own values.
# Do not commit your real .env file or share your API key.

# OpenAI API key used for course structuring, narration translation,
# slide-text translation and subtitle translation.
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model used for the above LLM calls (src/config.py).
OPENAI_MODEL=gpt-4o-mini
